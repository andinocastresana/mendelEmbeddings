data/
# Jupyter
.ipynb_checkpoints/

# Python
__pycache__/
*.pyc

# Node / Vite (cliente)
client/node_modules/
client/dist/
client/.vite/
node_modules/
dist/

# Modelos pesados copiados al public del cliente (no commit, se bajan / copian localmente)
client/public/models/

# Fixtures de spikes Track 2a (regenerables con los scripts en scripts/verify_*)
client/public/spike_fixtures*/

# Entornos
.venv/
env/
venv/

# Archivos generados pesados
data/output/
results/
figures/
plots/
exports/
*.png
*.jpg
*.jpeg
*.pdf
*.html

# Excepción al gitignore *.pdf: PDFs de snapshots de arquitectura
# (parte del patrón "doc vivo + snapshot inmutable versionado").
!_meta/**/*.pdf
*.parquet
*.feather
*.pkl
*.joblib
*.ipynb

# Claude Code: config local del usuario (preferencias personales:
# defaultMode, permisos extra que no se quieren compartir con el equipo).
# .claude/settings.json SÍ se commitea (allowlist compartido del proyecto).
.claude/settings.local.json

# Logs del wrapper scripts/dev-monitored.sh y del experimento heat-experiment.sh
# (muestras de CPU/temp; archivos temporales del experimento)
client/.dev-resources*
client/.heat-experiment*
client/.tsc-resources*
# Log del wrapper scripts/test-monitored.sh (corridas Python/test monitoreadas)
.test-resources*

# Scratch privado por agente de IA (ruido para otros agentes, no verdad del
# proyecto). El canal compartido es AGENTS_HANDOFF.md (sí se commitea).
_meta/agents/

# Worktrees de Claude Code (aislamiento por sesión; no son verdad del proyecto)
.claude/worktrees/
